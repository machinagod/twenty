# Twenty on Railway — environment template (our branch)
# Copy these into each Railway service's Variables. Values marked (shared) must be
# identical across the server and worker services.

# --- Core (shared, required) ---------------------------------------------------
# Railway Postgres plugin exposes DATABASE_URL; Twenty expects PG_DATABASE_URL.
# Set PG_DATABASE_URL to a reference: ${{Postgres.DATABASE_URL}}
PG_DATABASE_URL=postgres://user:password@host:5432/railway
# Railway Redis plugin: reference ${{Redis.REDIS_URL}}
REDIS_URL=redis://default:password@host:6379
# Public URL of the server service (Railway-provided domain or your custom domain)
SERVER_URL=https://your-app.up.railway.app
# Long random string, identical on server + worker. Generate: openssl rand -base64 32
APP_SECRET=replace_me_with_a_long_random_string

# --- Storage -------------------------------------------------------------------
# LOCAL needs a persistent volume mounted at the server's .local-storage.
# For production prefer S3 (set STORAGE_TYPE=s3 and the STORAGE_S3_* vars).
STORAGE_TYPE=local

# --- Telemetry (our branch defaults this to false; set explicitly to be safe) --
TELEMETRY_ENABLED=false

# --- Record-level locking (our feature; empty = disabled) ----------------------
# JSON array of rules. Example: members only see opportunities assigned to them.
# See packages/twenty-server/docs/RECORD_SCOPING.md.
RECORD_SCOPING_RULES=[{"roleLabel":"Member","objectNameSingular":"opportunity","logicalOperator":"AND","conditions":[{"column":"assigneeId","operator":"eq","currentWorkspaceMemberField":"id"}]}]

# --- Server service only --------------------------------------------------------
# Railway sets PORT; Twenty reads NODE_PORT. Reference: ${{PORT}}
NODE_PORT=3000

# --- Worker service only --------------------------------------------------------
# The worker must NOT run migrations/cron (the server already does).
# DISABLE_DB_MIGRATIONS=true
# DISABLE_CRON_JOBS_REGISTRATION=true
